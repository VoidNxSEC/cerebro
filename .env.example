# ---------------------------------------------------------------------------
# GCP / Discovery Engine
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=
GCP_REGION=us-central1
DATA_STORE_ID=

# ---------------------------------------------------------------------------
# Cerebro paths
# ---------------------------------------------------------------------------
# Primary runtime provider
CEREBRO_LLM_PROVIDER=azure

# Root directory where git repos are discovered (default: ~/arch)
CEREBRO_ARCH_PATH=

# Working data directory for analysis outputs (default: ./data)
CEREBRO_DATA_DIR=

# Path to the vector / knowledge base store (default: ./data/vectors)
CEREBRO_VECTOR_DB=

# ---------------------------------------------------------------------------
# TUI behaviour
# ---------------------------------------------------------------------------
# Set to "0" to connect LogsScreen to real Python logging instead of demo data
CEREBRO_DEMO_MODE=1
CEREBRO_JSON_LOGS=1

# ---------------------------------------------------------------------------
# Azure OpenAI provider  (CEREBRO_LLM_PROVIDER=azure)
# ---------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBED_DEPLOYMENT=
OPENAI_API_VERSION=
AZURE_ACR_NAME=
AZURE_ACR_LOGIN_SERVER=
AZURE_ACR_REPOSITORY=cerebro
AZURE_IMAGE_TAG=latest
AZURE_RESOURCE_GROUP=
AZURE_CONTAINER_APP_NAME=

# ---------------------------------------------------------------------------
# Anthropic Claude provider  (CEREBRO_LLM_PROVIDER=anthropic or claude)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_TIMEOUT=120

# ---------------------------------------------------------------------------
# Groq provider  (CEREBRO_LLM_PROVIDER=groq)
# ---------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_TIMEOUT=120

# ---------------------------------------------------------------------------
# Gemini provider  (CEREBRO_LLM_PROVIDER=gemini or google-gemini)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
# GEMINI_TIMEOUT=120

# ---------------------------------------------------------------------------
# Google Cloud deploy/runtime metadata
# ---------------------------------------------------------------------------
GCP_ARTIFACT_REGISTRY_REPOSITORY=cerebro
GCP_IMAGE_NAME=cerebro
GCP_IMAGE_TAG=latest
GCP_CLOUD_RUN_SERVICE=
GOOGLE_APPLICATION_CREDENTIALS=
